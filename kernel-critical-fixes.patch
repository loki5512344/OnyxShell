diff --git a/kernel/src/fs/vfs/create.rs b/kernel/src/fs/vfs/create.rs
index 807e197..45c10c4 100644
--- a/kernel/src/fs/vfs/create.rs
+++ b/kernel/src/fs/vfs/create.rs
@@ -44,12 +44,14 @@ pub unsafe fn create(path: &[u8], mode: u32) -> KResult<FdToken> {
     };
     let new_ino = onyxfs::create(parent_ino, filename, mode)?;
     let idx = alloc_fd(PERM_READ | PERM_WRITE | PERM_SEEK)?;
-    let p = proc::current();
-    let fd = &mut p.fds[idx];
-    fd.ino = new_ino;
-    fd.size = 0;
-    fd.fs = Fs::Onyx;
-    fd.pos = 0;
+    // Use fd_set so the fd is stored in the SAME table that alloc_fd used
+    // (G_KERNEL_FDS during boot, current().fds for user processes).
+    // The old code used `proc::current().fds[idx]` directly, which was
+    // wrong when alloc_fd used G_KERNEL_FDS — the fd was allocated in
+    // G_KERNEL_FDS but initialized in current().fds, causing EBADF on
+    // subsequent write_fd/read_fd calls.
+    super::fd_set(idx, new_ino, 0, Fs::Onyx, 0);
+    let fd = super::fd_get(idx);
     Ok(fd_token(idx, fd.epoch))
 }
 
diff --git a/kernel/src/proc/process/current.rs b/kernel/src/proc/process/current.rs
index a17c267..1ad2cd5 100644
--- a/kernel/src/proc/process/current.rs
+++ b/kernel/src/proc/process/current.rs
@@ -9,11 +9,13 @@ pub fn current_pid() -> u32 {
         if p.is_null() {
             return 0;
         }
-        if matches!((*p).state, ProcState::Running) {
-            (*p).pid
-        } else {
-            0
-        }
+        // Return the PID regardless of state — during a syscall the process
+        // might temporarily be in a non-Running state (e.g. if a timer tick
+        // preempted it), but it is still the "current" process for this hart.
+        // Returning 0 here would cause is_kernel_boot() to return true,
+        // which makes alloc_fd() use G_KERNEL_FDS instead of the process's
+        // own fd table — a serious bug.
+        (*p).pid
     }
 }
 
